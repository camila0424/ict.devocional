generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  passwordHash        String               @map("password_hash")
  avatarUrl           String?              @map("avatar_url")
  timezone            String               @default("Europe/Madrid")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  responses           DevotionalResponse[]
  pushSubs            PushSubscription[]
  reminder            Reminder?
  streak              Streak?
  progress            UserProgress[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model DevotionalPlan {
  id           String       @id @default(cuid())
  month        Int
  year         Int
  title        String
  visionTitle   String?      @map("vision_title")
  visionText    String?      @map("vision_text")
  strategyTitle String?      @map("strategy_title")
  strategyText  String?      @map("strategy_text")
  createdAt    DateTime     @default(now()) @map("created_at")
  entries      DailyEntry[]

  @@unique([month, year])
  @@map("devotional_plans")
}

model DailyEntry {
  id             String               @id @default(cuid())
  planId         String               @map("plan_id")
  dayNumber      Int                  @map("day_number")
  date           DateTime             @db.Date
  rawReadings    String               @map("raw_readings")
  youtubeVideoId String?              @map("youtube_video_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  plan           DevotionalPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  responses      DevotionalResponse[]
  readings       Reading[]

  @@unique([planId, dayNumber])
  @@index([date])
  @@map("daily_entries")
}

model Reading {
  id           String     @id @default(cuid())
  dailyEntryId String     @map("daily_entry_id")
  order        Int
  bookAbbr     String     @map("book_abbr")
  bookFull     String     @map("book_full")
  reference    String
  dailyEntry   DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)

  @@map("readings")
}

model DevotionalResponse {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  dailyEntryId   String     @map("daily_entry_id")
  message        String?
  promise        String?
  commandment    String?
  wrongAttitudes String?    @map("wrong_attitudes")
  teotherapy     String?
  petition       String?
  gratitude      String?
  pending        String?
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  dailyEntry     DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dailyEntryId])
  @@map("devotional_responses")
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("user_progress")
}

model Streak {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")
  current         Int       @default(0)
  best            Int       @default(0)
  lastCompletedAt DateTime? @map("last_completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  hour      Int
  minute    Int
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}
